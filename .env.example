# ─────────────────────────────────────────────────────────────────────────────
#  ExpressForge v2.0 — Unified Environment Template
#
#  Copy to the file matching your environment:
#    .env.development  (local dev — default)
#    .env.staging
#    .env.production
#
#  The API server auto-loads .env.<ENVIRONMENT> then falls back to .env.
#  NEVER commit any .env* file that contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development             # development | staging | production | test

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Docker Compose: use hostname 'postgres' (the service name)
# Manual local dev outside Docker: use 'localhost'
DATABASE_URL=postgresql://postgres:password@postgres:5432/expressforge

# ── Redis (rate limiting, session cache, TOTP dedup) ──────────────────────────
# Docker Compose: use hostname 'redis' (the service name)
# Production (Upstash): rediss://default:<password>@<host>:6379
REDIS_URL=redis://redis:6379

# ── JWT — server-side user authentication ─────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Field-level encryption (Fernet / AES-128-CBC + HMAC) ─────────────────────
# Encrypts emails at rest. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ── TOTP secret encryption (AES-256-GCM) ─────────────────────────────────────
# Separate key from ENCRYPTION_KEY — encrypts 2FA secrets at rest. Generate:
# python -c "import secrets; print(secrets.token_hex(32))"
TOTP_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY

# ── Email — Resend API ────────────────────────────────────────────────────────
# Used for: email verification, device approval, password reset
# Get key at: https://resend.com
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY
EMAIL_FROM=noreply@expressforge.dev
APP_URL=http://localhost:3000

# ── AI feature flag (server-side guard — users supply their own keys via BYOK) ─
AI_ENABLED=true
AI_TIMEOUT_SECONDS=20

# ── Rate limiting ─────────────────────────────────────────────────────────────
MAX_JOBS_PER_HOUR=10

# ── CORS — comma-separated list ───────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Internal Docker URL baked into Next.js rewrites at build time
API_INTERNAL_URL=http://api:8000
