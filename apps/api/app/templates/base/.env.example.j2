# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT={{ port }}
APP_URL=http://localhost:{{ port }}
{% if 'jwt' in auth %}

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
{% endif %}
{% if 'session' in auth %}

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string
SESSION_MAX_AGE=86400000
{% endif %}
{% if 'oauth_google' in auth %}

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:{{ port }}/api/auth/google/callback
{% endif %}
{% if 'api_key' in auth %}

# ── API Key Auth ──────────────────────────────────────────────────────────────
API_KEY=change_me_to_a_secure_random_key
{% endif %}
{% if 'magic_link' in auth %}

# ── Magic Link ────────────────────────────────────────────────────────────────
MAGIC_LINK_SECRET=change_me_to_a_long_random_string
{% endif %}
{% if 'mongodb' in database %}

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/{{ project_name }}
{% endif %}
{% if 'postgres_prisma' in database %}

# ── PostgreSQL (Prisma) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/{{ project_name }}
{% endif %}
{% if 'mysql_prisma' in database %}

# ── MySQL (Prisma) ────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/{{ project_name }}
{% endif %}
{% if 'sqlite_prisma' in database %}

# ── SQLite (Prisma) ───────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
{% endif %}
{% if 'postgres_sequelize' in database %}

# ── PostgreSQL (Sequelize) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME={{ project_name }}
DB_USER=postgres
DB_PASSWORD=password
{% endif %}
{% if 'redis' in database %}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
{% endif %}
{% if 'cors' in middleware %}

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
{% endif %}
{% if 'winston' in middleware or 'pino' in middleware %}

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FILE=logs/app.log
{% endif %}
{% if 'multer_local' in file_upload %}

# ── File Upload (local) ───────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
{% endif %}
{% if 'multer_s3' in file_upload %}

# ── File Upload (AWS S3) ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=your_bucket_name
MAX_FILE_SIZE=52428800
{% endif %}
{% if 'multer_cloudinary' in file_upload %}

# ── File Upload (Cloudinary) ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER={{ project_name }}
{% endif %}
{% if 'nodemailer_smtp' in email %}

# ── Email (SMTP / Nodemailer) ─────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
{% endif %}
{% if 'resend' in email %}

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@{{ project_name }}.dev
{% endif %}
{% if 'bullmq' in queues %}

# ── Queue (BullMQ / Redis) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
{% endif %}
