{
  "name": "{{ project_name }}",
  "version": "1.0.0",
  "description": "Generated by ExpressForge",
  "main": "{% if language == 'typescript' %}dist/app.js{% else %}src/app.js{% endif %}",
  "scripts": {
{% if language == 'typescript' %}
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "typecheck": "tsc --noEmit",
{% else %}
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
{% endif %}
{% if include_tests %}
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
{% endif %}
    "lint": "eslint src/**/*.{% if language == 'typescript' %}ts{% else %}js{% endif %}"
  },
  "dependencies": {
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
{% if 'cors' in middleware %}
    "cors": "^2.8.5",
{% endif %}
{% if 'helmet' in middleware %}
    "helmet": "^7.1.0",
{% endif %}
{% if 'morgan' in middleware %}
    "morgan": "^1.10.0",
{% endif %}
{% if 'rate_limit' in middleware %}
    "express-rate-limit": "^7.3.1",
{% endif %}
{% if 'compression' in middleware %}
    "compression": "^1.7.4",
{% endif %}
{% if 'body_parser' in middleware %}
    "body-parser": "^1.20.2",
{% endif %}
{% if 'cookie_parser' in middleware %}
    "cookie-parser": "^1.4.6",
{% endif %}
{% if 'zod' in middleware %}
    "zod": "^3.23.8",
{% endif %}
{% if 'joi' in middleware %}
    "joi": "^17.13.3",
{% endif %}
{% if 'express_validator' in middleware %}
    "express-validator": "^7.2.0",
{% endif %}
{% if 'winston' in middleware %}
    "winston": "^3.13.0",
{% endif %}
{% if 'pino' in middleware %}
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
{% endif %}
{% if 'jwt' in auth %}
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
{% endif %}
{% if 'session' in auth %}
    "express-session": "^1.18.0",
    "connect-pg-simple": "^9.0.1",
{% endif %}
{% if 'oauth_google' in auth %}
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
{% endif %}
{% if 'magic_link' in auth %}
    "nodemailer": "^6.9.14",
{% endif %}
{% if 'mongodb' in database %}
    "mongoose": "^8.4.4",
{% endif %}
{% if 'postgres_prisma' in database or 'mysql_prisma' in database or 'sqlite_prisma' in database %}
    "@prisma/client": "^5.16.1",
{% endif %}
{% if 'postgres_sequelize' in database %}
    "sequelize": "^6.37.3",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
{% endif %}
{% if 'redis' in database %}
    "ioredis": "^5.4.1",
{% endif %}
{% if 'multer_local' in file_upload %}
    "multer": "^1.4.5-lts.1",
{% endif %}
{% if 'multer_s3' in file_upload %}
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "@aws-sdk/client-s3": "^3.600.0",
{% endif %}
{% if 'multer_cloudinary' in file_upload %}
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.3.1",
    "multer-storage-cloudinary": "^4.0.0",
{% endif %}
{% if 'nodemailer_smtp' in email %}
    "nodemailer": "^6.9.14",
{% endif %}
{% if 'resend' in email %}
    "resend": "^3.4.0",
{% endif %}
{% if 'bullmq' in queues %}
    "bullmq": "^5.12.7",
    "ioredis": "^5.4.1",
{% endif %}
{% if 'node_cron' in queues %}
    "node-cron": "^3.0.3",
{% endif %}
{% if 'socket_io' in websockets %}
    "socket.io": "^4.7.5",
{% endif %}
{% if 'ws' in websockets %}
    "ws": "^8.18.0",
{% endif %}
{% if include_swagger or 'swagger_ui' in middleware %}
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
{% endif %}
    "_placeholder": "1"
  },
  "devDependencies": {
{% if language == 'typescript' %}
    "typescript": "^5.5.3",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
{% if 'cors' in middleware %}
    "@types/cors": "^2.8.17",
{% endif %}
{% if 'morgan' in middleware %}
    "@types/morgan": "^1.9.9",
{% endif %}
{% if 'compression' in middleware %}
    "@types/compression": "^1.7.5",
{% endif %}
{% if 'cookie_parser' in middleware %}
    "@types/cookie-parser": "^1.4.7",
{% endif %}
{% if 'winston' in middleware %}
    "@types/winston": "^2.4.4",
{% endif %}
{% if 'pino' in middleware %}
    "@types/pino-http": "^5.8.4",
{% endif %}
{% if 'jwt' in auth %}
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
{% endif %}
{% if 'session' in auth %}
    "@types/express-session": "^1.18.0",
{% endif %}
{% if 'oauth_google' in auth %}
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
{% endif %}
{% if 'magic_link' in auth or 'nodemailer_smtp' in email %}
    "@types/nodemailer": "^6.4.15",
{% endif %}
{% if 'multer_local' in file_upload or 'multer_s3' in file_upload or 'multer_cloudinary' in file_upload %}
    "@types/multer": "^1.4.11",
{% endif %}
{% if 'node_cron' in queues %}
    "@types/node-cron": "^3.0.11",
{% endif %}
{% if 'ws' in websockets %}
    "@types/ws": "^8.5.11",
{% endif %}
{% if include_swagger or 'swagger_ui' in middleware %}
    "@types/swagger-ui-express": "^4.1.6",
    "@types/swagger-jsdoc": "^6.0.4",
{% endif %}
{% endif %}
{% if include_tests %}
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
{% if language == 'typescript' %}
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.2.2",
{% endif %}
{% endif %}
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4"
  }{% if 'postgres_prisma' in database or 'mysql_prisma' in database or 'sqlite_prisma' in database %},
  "prisma": {
    "schema": "prisma/schema.prisma"
  }{% endif %}
}
