{% if language == 'typescript' %}
import crypto from 'crypto';
import nodemailer from 'nodemailer';

const MAGIC_LINK_SECRET = process.env.MAGIC_LINK_SECRET as string;
const MAGIC_LINK_EXPIRE_MS = 15 * 60 * 1000; // 15 minutes

// In production replace with a real token store (Redis or DB)
const tokenStore = new Map<string, { email: string; expires: number }>();

export function generateMagicToken(email: string): string {
  const token = crypto.randomBytes(32).toString('hex');
  tokenStore.set(token, { email, expires: Date.now() + MAGIC_LINK_EXPIRE_MS });
  return token;
}

export function verifyMagicToken(token: string): string | null {
  const entry = tokenStore.get(token);
  if (!entry || Date.now() > entry.expires) return null;
  tokenStore.delete(token);
  return entry.email;
}

export async function sendMagicLink(email: string, token: string): Promise<void> {
  const transporter = nodemailer.createTransport({
    host: process.env.SMTP_HOST,
    port: Number(process.env.SMTP_PORT) || 587,
    auth: { user: process.env.SMTP_USER, pass: process.env.SMTP_PASS },
  });
  const link = `${process.env.APP_URL}/auth/verify?token=${token}`;
  await transporter.sendMail({
    from: process.env.SMTP_FROM || 'noreply@example.com',
    to: email,
    subject: 'Your sign-in link',
    text: `Click to sign in: ${link}\n\nExpires in 15 minutes.`,
    html: `<p>Click <a href="${link}">here</a> to sign in. Expires in 15 minutes.</p>`,
  });
}
