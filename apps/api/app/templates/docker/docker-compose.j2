version: "3.9"

services:
  app:
    build: .
    ports:
      - "{{ port }}:{{ port }}"
    environment:
      - NODE_ENV=production
      - PORT={{ port }}
{% if auth == 'jwt' %}
      - JWT_SECRET=${JWT_SECRET}
      - JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
{% endif %}
{% if auth == 'session' %}
      - SESSION_SECRET=${SESSION_SECRET}
{% endif %}
{% if database == 'mongodb' %}
      - MONGODB_URI=mongodb://mongo:27017/{{ project_name }}
{% elif database in ['postgres_prisma', 'mysql_prisma', 'postgres_sequelize'] %}
      - DATABASE_URL=${DATABASE_URL}
{% endif %}
    depends_on:
{% if database == 'mongodb' %}
      - mongo
{% elif database in ['postgres_prisma', 'mysql_prisma', 'postgres_sequelize'] %}
      - db
{% endif %}
    restart: unless-stopped
{% if database == 'mongodb' %}

  mongo:
    image: mongo:7-jammy
    volumes:
      - mongo_data:/data/db
    restart: unless-stopped
{% elif database in ['postgres_prisma', 'postgres_sequelize'] %}

  db:
    image: postgres:15-alpine
    environment:
      POSTGRES_DB: {{ project_name }}
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-password}
    volumes:
      - pg_data:/var/lib/postgresql/data
    restart: unless-stopped
{% elif database == 'mysql_prisma' %}

  db:
    image: mysql:8.0
    environment:
      MYSQL_DATABASE: {{ project_name }}
      MYSQL_ROOT_PASSWORD: ${DB_PASSWORD:-password}
    volumes:
      - mysql_data:/var/lib/mysql
    restart: unless-stopped
{% endif %}

volumes:
{% if database == 'mongodb' %}
  mongo_data:
{% elif database in ['postgres_prisma', 'postgres_sequelize'] %}
  pg_data:
{% elif database == 'mysql_prisma' %}
  mysql_data:
{% endif %}
